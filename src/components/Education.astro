---
const eduItems = [
  { index: 0, period: "2023 – Present", school: "Universitas Terbuka", major: "Business Management (Undergraduate)" },
  { index: 1, period: "Jun 2023 – Nov 2023", school: "Binar Academy", major: "Data Science Bootcamp" },
  { index: 2, period: "Dec 2022 – May 2023", school: "Binar Academy", major: "Mobile Development Bootcamp" },
  { index: 3, period: "Jul 2017 – Aug 2019", school: "SMKN 1 Sampit", major: "Information Technology Engineering" },
];
---

<section id="education" class="section section-alt">
  <div class="container">
    <h2 class="fade-in section-title" data-i18n="education.subtitle">My Learning Path</h2>
    <div class="timeline edu-timeline" id="timelineEdu">
      <div class="tl-track"></div>
      {eduItems.map(item => (
        <div class="tl-item" data-index={item.index}>
          <div class="tl-dot" data-index={item.index}></div>
          <div class="tl-card edu-card">
            <div class="tl-period" data-i18n={`edu.${item.index}.period`}>{item.period}</div>
            <h3 class="tl-role edu-school" data-i18n={`edu.${item.index}.school`}>{item.school}</h3>
            <div class="tl-company edu-major" data-i18n={`edu.${item.index}.major`}>{item.major}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .edu-timeline .tl-card {
    padding: 1rem 1.5rem;
  }

  .edu-timeline .tl-role {
    font-size: 1rem;
    margin-bottom: 0.15rem;
  }

  .edu-timeline .tl-track {
    position: relative;
    height: 4px;
    width: 100%;
    background: var(--border);
    border-radius: 4px;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .edu-timeline .tl-track::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: var(--fill, 0%);
    background: linear-gradient(to right, var(--accent), #60a5fa);
    border-radius: 4px;
    transition: width 0.6s ease-out;
  }

  .edu-timeline .tl-dot {
    position: absolute;
    left: -2.5rem;
    top: 4px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--border);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s ease;
  }

  .edu-timeline .tl-dot::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.4s ease;
  }

  .edu-timeline .tl-dot.active {
    border-color: var(--accent);
    background: var(--bg);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.12);
  }

  .edu-timeline .tl-dot.active::after {
    background: var(--accent);
  }

  .edu-timeline .tl-item {
    position: relative;
    padding-bottom: 2.5rem;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .edu-timeline .tl-item:last-child {
    padding-bottom: 0;
  }

  .edu-timeline .tl-item.active {
    opacity: 1;
    transform: translateX(0);
  }

  .edu-timeline .tl-item.active .tl-card {
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .edu-school {
    font-size: 1rem;
  }

  .edu-major {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .edu-timeline {
      padding-left: 2rem;
    }
  }
</style>
