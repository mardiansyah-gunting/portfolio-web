---
const eduItems = [
  { index: 0, period: "Jun 2023 – Nov 2023", school: "Binar Academy", major: "Data Science Bootcamp" },
  { index: 1, period: "Dec 2022 – May 2023", school: "Binar Academy", major: "Mobile Software Engineering Bootcamp" },
  { index: 2, period: "2020 – Present", school: "Universitas Terbuka", major: "Business Management (Undergraduate)" },
  { index: 3, period: "Jul 2017 – Aug 2019", school: "SMKN 1 Sampit", major: "Information Technology Engineering" },
];
---

<section id="education" class="section section-alt">
  <div class="container">
    <h2 class="section-title" data-i18n="education.subtitle">My Learning Path</h2>
    <div class="edu-grid">
      {eduItems.map(item => (
        <div class="edu-card fade-in">
          <div class="edu-period" data-i18n={`edu.${item.index}.period`}>{item.period}</div>
          <h3 class="edu-school" data-i18n={`edu.${item.index}.school`}>{item.school}</h3>
          <div class="edu-major" data-i18n={`edu.${item.index}.major`}>{item.major}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .edu-card {
    background: var(--bg);
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .edu-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .edu-school {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.25rem;
  }

  .edu-major {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
