---
import fs from 'fs';
import path from 'path';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const imgDir = path.resolve('public/images/jobs');
const imgExts = new Set(['.jpg', '.jpeg', '.png', '.webp', '.gif', '.avif', '.svg']);

function getJobImages(slug) {
  const dir = path.join(imgDir, slug);
  try {
    return fs.readdirSync(dir)
      .filter(f => imgExts.has(path.extname(f).toLowerCase()))
      .map(f => `${baseUrl}/images/jobs/${slug}/${f}`);
  } catch {
    return [];
  }
}

const items = [
  { date: "May 2024 – Present", company: "Fairventures Digital GmbH", slug: "customer-success-manager", logo: "fairventures-digital.png", role: "Customer Success Manager", desc: "Designed and implemented new SOPs across departments, eliminating bottlenecks. Pioneered customer-centric operational frameworks. Led cross-functional projects for operational excellence. Established KPI dashboards for data-driven decision-making." },
  { date: "May 2023 – May 2024", company: "Fairventures Digital GmbH", slug: "customer-success-engineer", logo: "fairventures-digital.png", role: "Customer Success Engineer", desc: "Conducted field visits assessing TREEO technology user experience. Monitored daily activities on TREEO cloud. Enhanced UI/UX of TREEO Apps. Provided comprehensive user support and training." },
  { date: "Oct 2022 – Apr 2023", company: "Freelance Consultant", slug: "junior-android-developer", logo: "konsultan-freelance.svg", role: "Junior Android Developer", desc: "Built Android apps using Android Studio with Kotlin and Java. Created mobile and web app mockups." },
  { date: "Feb 2022 – Mar 2023", company: "Fairventures Worldwide gGmbH", slug: "hpps-coordinator-assistant", logo: "fairventures-worldwide.jpg", role: "HPPS Project Coordinator Assistant", desc: "Prepared data flow and safety materials. Managed data collection and processing. Ensured safety procedures compliance across all staff." },
  { date: "Oct 2019 – Feb 2022", company: "Fairventures Worldwide gGmbH", slug: "general-affairs-officer", logo: "fairventures-worldwide.jpg", role: "General Affairs Officer", desc: "Managed office contracts and asset handovers. Coordinated security and driver operations. Maintained fleet of four vehicles. Tracked all company assets." },
  { date: "Jul 2019 – Sep 2019", company: "CV Karya Hidup Sentosa", slug: "demonstration-officer", logo: "cv-karya-hidup-sentosa.jpg", role: "Demonstration Officer", desc: "Handled B2B communication. Demonstrated Quick Tractor product to oil palm plantations across Sumatra, Sulawesi, and Borneo." },
  { date: "Jul 2018 – Dec 2018", company: "Badan Pusat Statistik", slug: "intern-bps", logo: "bps.png", role: "Intern", desc: "Designed the cover for the annual book report. Created posters and vector graphics for the Annual Book." },
];
---

<section id="experience" class="section section-alt">
  <div class="hs-wrap" id="hsWrap">
    <div class="hs-sticky">
      <div class="hs-top">
        <div class="hs-top-inner">
          <h2 class="section-title" data-i18n="experience.subtitle">My Professional Journey</h2>
          <div class="hs-track">
            <div class="hs-track-fill" id="hsTrackFill"></div>
          </div>
        </div>
      </div>
      <div class="hs-stage">
        <div class="timeline" id="timelineExp">
          {items.map((item, i) => {
            const imgs = getJobImages(item.slug);
            return (
              <div class="tl-item" data-index={i}>
                <div class="tl-header">
                  <img src={`${baseUrl}/images/logos/${item.logo}`} alt="" class="tl-logo" loading="lazy" />
                  <div class="tl-company" data-i18n={`exp.${i}.company`}>{item.company}</div>
                  <div class="tl-period" data-i18n={`exp.${i}.period`}>{item.date}</div>
                  <span class="tl-step">{i + 1} / {items.length}</span>
                </div>
                <div class="tl-body">
                  <h3 class="tl-role" data-i18n={`exp.${i}.role`}>{item.role}</h3>
                  <p class="tl-desc" data-i18n={`exp.${i}.desc`}>{item.desc}</p>
                </div>
                {imgs.length > 0 ? (
                  <div class="tl-gallery" data-gallery={item.slug}>
                    {imgs.map((src, j) => (
                      <img src={src} alt={`${item.company} ${j + 1}`} class="tl-gallery-img" loading="lazy" data-index={j} />
                    ))}
                  </div>
                ) : null}
              </div>
            );
          })}
        </div>
        <div class="swipe-hint" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hs-wrap {
    position: relative;
    width: 100%;
  }
  .hs-sticky {
    position: sticky;
    top: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--section-alt-bg, #f8fafc);
  }
  .hs-top {
    flex-shrink: 0;
    padding: 5rem 2rem 0;
  }
  .hs-top-inner {
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }
  .hs-top .section-title {
    margin-bottom: 1rem;
  }
  .hs-track {
    height: 4px;
    width: 100%;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .hs-track-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, var(--accent), #60a5fa);
    border-radius: 4px;
  }
  .hs-stage {
    flex: 1;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    padding: 0 2rem 2rem;
    position: relative;
  }
  .swipe-hint {
    display: none;
  }
  .timeline {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    will-change: transform;
    gap: 2rem;
    width: 100%;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tl-item {
    width: 100vw;
    max-width: 1000px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    opacity: 0.3;
    transition: opacity 0.5s ease, border-color 0.5s, box-shadow 0.5s;
    padding: 1.5rem 2rem;
    background: var(--bg);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    margin-right: 2rem;
    box-sizing: border-box;
    align-self: center;
    max-height: 70vh;
  }
  .tl-item.active {
    opacity: 1;
    border-color: rgba(59, 130, 246, 0.25);
    box-shadow: 0 8px 32px rgba(59, 130, 246, 0.08);
  }
  .tl-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.5rem 0 0.75rem 0;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .tl-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
    background: #fff;
  }
  .tl-company {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary);
    white-space: nowrap;
  }
  .tl-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }
  .tl-step {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted, #94a3b8);
    margin-left: auto;
    white-space: nowrap;
  }
  .tl-body {
    flex: 1;
    overflow-y: auto;
    padding: 0.25rem 0;
  }
  .tl-role {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 0.3rem;
    line-height: 1.25;
  }
  .tl-desc {
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.65;
  }
  .tl-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    max-height: 30vh;
    overflow: hidden;
  }
  .tl-gallery-img {
    width: 100%;
    height: 80px;
    object-fit: cover;
    display: block;
    border-radius: 8px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .tl-gallery-img:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }

  @media (max-width: 768px) {
    .hs-wrap {
      height: auto !important;
    }
    .hs-sticky {
      position: relative;
      overflow: visible;
      height: auto !important;
    }
    .hs-top {
      padding: 4.5rem 1rem 0;
    }
    .hs-stage {
      padding: 0 1rem 2rem;
      overflow: visible;
      height: auto;
    }
    .swipe-hint {
      display: none !important;
    }
    .timeline {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      transform: none !important;
      transition: none;
    }
    .tl-item {
      width: 100%;
      max-width: none;
      max-height: none;
      padding: 1rem;
      margin-right: 0;
      opacity: 1;
      align-self: auto;
    }
    .tl-header {
      gap: 0.5rem;
      padding: 0.25rem 0 0.5rem 0;
    }
    .tl-logo {
      width: 32px;
      height: 32px;
    }
    .tl-company {
      font-size: 0.85rem;
      white-space: normal;
      word-break: break-word;
    }
    .tl-period {
      font-size: 0.75rem;
    }
    .tl-step {
      font-size: 0.7rem;
    }
    .tl-role {
      font-size: 1rem;
    }
    .tl-desc {
      font-size: 0.82rem;
    }
    .tl-body {
      flex: 0 1 auto;
      overflow-y: visible;
      padding-bottom: 0;
    }
    .tl-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
      padding-top: 0.35rem;
      border-top: 1px solid var(--border);
      max-height: none;
    }
    .tl-gallery-img {
      height: 60px;
      border-radius: 6px;
    }
  }

  @media (max-width: 480px) {
    .tl-item {
      padding: 0.75rem 0.85rem;
      max-height: none;
    }
    .tl-header {
      gap: 0.35rem;
    }
    .tl-logo {
      width: 28px;
      height: 28px;
    }
    .tl-role {
      font-size: 0.95rem;
    }
    .tl-desc {
      font-size: 0.78rem;
      line-height: 1.5;
    }
    .tl-body {
      flex: 0 1 auto;
      overflow-y: visible;
      padding-bottom: 0;
    }
    .tl-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 3px;
      padding-top: 0.35rem;
      border-top: 1px solid var(--border);
      max-height: none;
    }
    .tl-gallery-img {
      height: 50px;
      border-radius: 4px;
    }
    .tl-step {
      font-size: 0.65rem;
    }
  }

  .lb-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    cursor: zoom-out;
  }
  .lb-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .lb-overlay img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    cursor: default;
    user-select: none;
  }
  .lb-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: none;
  }
  .lb-close:hover { background: rgba(255,255,255,0.25); }
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: none;
    user-select: none;
  }
  .lb-nav:hover { background: rgba(255,255,255,0.25); }
  .lb-prev { left: 1rem; }
  .lb-next { right: 1rem; }
  .lb-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    font-weight: 500;
    background: rgba(0,0,0,0.5);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
  }
</style>

<div class="lb-overlay" id="lightbox">
  <button class="lb-close" id="lbClose">&times;</button>
  <button class="lb-nav lb-prev" id="lbPrev">&lsaquo;</button>
  <img src="" alt="lightbox" id="lbImg" />
  <button class="lb-nav lb-next" id="lbNext">&rsaquo;</button>
  <div class="lb-counter" id="lbCounter"></div>
</div>

<script>
(function() {
  var wrap = document.getElementById('hsWrap');
  var sticky = document.querySelector('.hs-sticky');
  var stage = document.querySelector('.hs-stage');
  var timeline = document.getElementById('timelineExp');
  var trackFill = document.getElementById('hsTrackFill');
  var items = timeline.querySelectorAll('.tl-item');
  var itemCount = items.length;
  var currentSlide = -1;
  var mobileObserver = null;

  function setHeights() {
    var vh = window.innerHeight;
    var mobile = window.innerWidth <= 768;
    if (mobile) {
      if (sticky) sticky.style.height = '';
      if (wrap) wrap.style.height = '';
      return 0;
    }
    if (sticky) sticky.style.height = vh + 'px';
    if (wrap) {
      wrap.style.height = itemCount * vh + 'px';
      return wrap.offsetHeight - vh;
    }
    return 0;
  }
  var maxScroll = setHeights();

  function getProgress() {
    if (maxScroll <= 0) return 0;
    var wrapTop = wrap.getBoundingClientRect().top + window.pageYOffset;
    var scrolled = Math.max(0, Math.min(maxScroll, window.pageYOffset - wrapTop));
    return scrolled / maxScroll;
  }

  function setSlide(snapped) {
    if (snapped === currentSlide) return;
    currentSlide = snapped;
    var snapProgress = (itemCount > 1) ? snapped / (itemCount - 1) : 0;
    trackFill.style.width = (snapProgress * 100) + '%';
    items.forEach(function(it, i) {
      it.classList.toggle('active', i === snapped);
    });
  }

  function updateDesktop() {
    var progress = getProgress();
    var snapped = Math.round(progress * (itemCount - 1));
    var itemW = items[0].offsetWidth;
    var gap = parseFloat(getComputedStyle(timeline).gap) || 0;
    var maxTx = (itemW + gap) * (itemCount - 1);
    var snapProgress = (itemCount > 1) ? snapped / (itemCount - 1) : 0;
    timeline.style.transform = 'translateX(-' + (snapProgress * maxTx) + 'px)';
    setSlide(snapped);
  }

  function setupMobile() {
    timeline.style.transform = '';
    timeline.style.transition = '';
    window.removeEventListener('scroll', updateDesktop);
    if (mobileObserver) {
      mobileObserver.disconnect();
      mobileObserver = null;
    }
  }

  function setupDesktop() {
    if (mobileObserver) {
      mobileObserver.disconnect();
      mobileObserver = null;
    }
    timeline.style.transform = '';
    timeline.style.transition = '';
    updateDesktop();
    window.addEventListener('scroll', updateDesktop, { passive: true });
  }

  function init() {
    var mobile = window.innerWidth <= 768;
    if (mobile) {
      setupMobile();
    } else {
      setupDesktop();
    }
  }
  init();

  window.addEventListener('resize', function() {
    maxScroll = setHeights();
    var mobile = window.innerWidth <= 768;
    window.removeEventListener('scroll', updateDesktop);
    if (mobileObserver) {
      mobileObserver.disconnect();
      mobileObserver = null;
    }
    if (mobile) {
      setupMobile();
    } else {
      setupDesktop();
    }
  });

  var overlay = document.getElementById('lightbox');
  var imgEl = document.getElementById('lbImg');
  var closeBtn = document.getElementById('lbClose');
  var prevBtn = document.getElementById('lbPrev');
  var nextBtn = document.getElementById('lbNext');
  var counter = document.getElementById('lbCounter');
  var currentImages = [];
  var currentIndex = 0;

  function openLb(index, images) {
    currentImages = images;
    currentIndex = index;
    showLb();
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLb() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }
  function showLb() {
    if (currentImages.length === 0) return;
    imgEl.src = currentImages[currentIndex];
    counter.textContent = (currentIndex + 1) + ' / ' + currentImages.length;
    prevBtn.style.display = currentImages.length > 1 ? 'flex' : 'none';
    nextBtn.style.display = currentImages.length > 1 ? 'flex' : 'none';
  }
  function prevLb() {
    if (currentImages.length < 2) return;
    currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
    showLb();
  }
  function nextLb() {
    if (currentImages.length < 2) return;
    currentIndex = (currentIndex + 1) % currentImages.length;
    showLb();
  }

  document.addEventListener('click', function(e) {
    var target = e.target;
    if (target.classList.contains('tl-gallery-img')) {
      var gallery = target.closest('.tl-gallery');
      if (!gallery) return;
      var imgs = gallery.querySelectorAll('.tl-gallery-img');
      var images = Array.from(imgs).map(function(img) { return img.src; });
      var index = parseInt(target.dataset.index, 10);
      openLb(index, images);
      e.preventDefault();
    }
  });
  closeBtn.addEventListener('click', closeLb);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeLb();
  });
  prevBtn.addEventListener('click', prevLb);
  nextBtn.addEventListener('click', nextLb);
  document.addEventListener('keydown', function(e) {
    if (!overlay.classList.contains('open')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') prevLb();
    if (e.key === 'ArrowRight') nextLb();
  });

  var touchStartX = 0;
  overlay.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  overlay.addEventListener('touchend', function(e) {
    var diff = e.changedTouches[0].screenX - touchStartX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) prevLb();
      else nextLb();
    }
  }, { passive: true });
})();
</script>
