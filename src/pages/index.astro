---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <About />
    <Experience />
    <Skills />
    <Education />
    <Contact />

    <div class="section-indicator" id="sectionIndicator">
      <div class="si-track">
        <div class="si-line"></div>
        {['home', 'about', 'experience', 'skills', 'education', 'contact'].map(id => (
          <a href={`#${id}`} class="si-dot" data-section={id}>
            <span class="si-label" data-i18n={`nav.${id}`}>{id}</span>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />

  <style>
    .section-indicator {
      position: fixed;
      right: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 90;
      pointer-events: none;
    }

    .si-track {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      pointer-events: auto;
    }

    .si-line {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 1px;
      background: var(--border);
      transform: translateX(-50%);
    }

    .si-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--border);
      border: 2px solid var(--bg);
      transition: all 0.3s;
      position: relative;
      z-index: 1;
      flex-shrink: 0;
    }

    .si-dot.active {
      width: 10px;
      height: 10px;
      background: var(--primary);
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(15, 43, 76, 0.15);
    }

    .si-label {
      display: none;
      position: absolute;
      right: calc(100% + 10px);
      top: 50%;
      transform: translateY(-50%);
      font-size: 0.65rem;
      font-weight: 700;
      color: #fff;
      background: var(--primary);
      padding: 0.15rem 0.5rem;
      border-radius: 100px;
      border: none;
      box-shadow: 0 2px 8px rgba(15, 43, 76, 0.15);
      white-space: nowrap;
      pointer-events: none;
      text-transform: capitalize;
      letter-spacing: 0.02em;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .si-label.show {
      opacity: 1;
    }

    @media (max-width: 768px) {
      .si-label {
        display: block;
        font-size: 0.65rem;
        padding: 0.15rem 0.4rem;
      }
    }
  </style>

  <script>
    var fadeObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('visible', entry.isIntersecting);
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(function(el) { fadeObserver.observe(el); });

    var sectionIds = ['home', 'about', 'experience', 'skills', 'education', 'contact'];
    var dots = {};
    sectionIds.forEach(function(id) {
      var el = document.querySelector('.si-dot[data-section="' + id + '"]');
      if (el) dots[id] = el;
    });

    function showLabelBriefly(dot) {
      if (!dot) return;
      var label = dot.querySelector('.si-label');
      if (!label) return;
      label.classList.remove('show');
      void label.offsetWidth;
      label.classList.add('show');
      clearTimeout(label._hide);
      label._hide = setTimeout(function() {
        label.classList.remove('show');
      }, 1400);
    }

    var activeIndex = 0;
    var ticking = false;

    function updateActiveSection() {
      var bestId = null;
      var bestDist = Infinity;
      var viewCenter = window.innerHeight / 2;

      sectionIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        var rect = el.getBoundingClientRect();
        var elCenter = rect.top + rect.height / 2;
        var dist = Math.abs(elCenter - viewCenter);
        if (dist < bestDist) {
          bestDist = dist;
          bestId = id;
        }
      });

      if (bestId) {
        var idx = sectionIds.indexOf(bestId);
        if (idx >= 0 && idx !== activeIndex) {
          if (dots[sectionIds[activeIndex]]) dots[sectionIds[activeIndex]].classList.remove('active');
          activeIndex = idx;
          if (dots[bestId]) dots[bestId].classList.add('active');
        }
      }
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updateActiveSection();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateActiveSection();

    sectionIds.forEach(function(id) {
      var dot = dots[id];
      if (dot) {
        dot.addEventListener('mouseenter', function() { showLabelBriefly(dot); });
        dot.addEventListener('touchstart', function() { showLabelBriefly(dot); }, { passive: true });
      }
    });



    function initTimeline(tlId) {
      var tl = document.getElementById(tlId);
      if (!tl) return;
      var track = tl.querySelector('.tl-track');
      var items = tl.querySelectorAll('.tl-item');
      if (!items.length) return;

      function updateFill() {
        var activeCount = tl.querySelectorAll('.tl-item.active').length;
        var pct = Math.min(100, Math.round((activeCount / items.length) * 100));
        track.style.setProperty('--fill', pct + '%');
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            var dot = entry.target.querySelector('.tl-dot');
            if (dot) dot.classList.add('active');
          }
        });
        updateFill();
      }, { threshold: 0.25, rootMargin: '0px 0px -40px 0px' });

      items.forEach(function(item) { observer.observe(item); });
      updateFill();
    }

    initTimeline('timelineEdu');
  </script>
</BaseLayout>
